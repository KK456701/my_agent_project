# ============================================================
# 环境变量配置模板 — 复制为 .env 并填入真实值
# ============================================================

# --- LLM 配置 ---
# 必填：你的 OpenAI API Key（或其他兼容接口的 Key）
OPENAI_API_KEY=sk-your-key-here

# 可选：自定义 API Base（使用中转服务时设置）
# OPENAI_API_BASE=https://api.openai.com/v1

# 主模型（用于深度辩论）
MODEL_NAME=gpt-4o

# 轻量模型（用于快速通道初步扫描）
LITE_MODEL_NAME=gpt-4o-mini

# 模型温度（越低越确定性）
MODEL_TEMPERATURE=0.2

# --- 辩论参数 ---
# 最多辩论轮数（超过后升级给人类）
MAX_DEBATE_ROUNDS=3

# 共识阈值
CONSENSUS_THRESHOLD=0.8

# --- 分级路由 ---
# 小于此行数的 PR 走快速通道
FAST_TRACK_MAX_LINES=50

# --- 日志 ---
LOG_LEVEL=INFO

# --- GitHub 集成 ---
# GitHub Personal Access Token（classic），勾选 repo 权限
# 获取: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here
